res = simulate(vth, c, ci, f, fi, pr, pri, M, Mi, tauv, tmax, delta_t, navgs)

#%% Plot
fs=15
plt.plot(1000*np.array(res[0]), 1000*np.array(res[1]), label='membrane potential')
plt.plot(1000*np.array(res[0]), 1000*np.array(res[2]), label='threshold potential')
