#%% Adaptive threshold - positive

import numpy as np
from matplotlib.pyplot import plot as pt
import matplotlib.pyplot as plt
from numpy.random import exponential, binomial, gamma
from numpy import exp
from numpy import sqrt as Sqrt
from numpy import log as Log
import pandas as pd

def simp(vth0, c, ci, f, fi, pr, pri, M, Mi, tauv, tmax, delta_t,
         tauvth, v1, alpha, navgs):

    tavgs=[]
    cavgs=[]

    for _ in range(navgs):

        vlist=[]
        vthlist=[]
        tlist=[]
        prelist=[]
        prelisti=[]
        postlist=[]

        e=1e-9
        tcurr=0
        ratio = 0#.3
        timer = delta_t
        v=0
        vth=vth0
        vthlist.append(vth)
        vlist.append(0)
        tlist.append(0)
        while tcurr < tmax:
            
            t0=exponential(1/(f+e))
            t1=exponential(1/(fi+e))
            t2=timer
            
            if t0<t1 and t0<t2: # AP occurrs
                b = binomial(M, pr)
                v=v+c*b
                tmin = t0
                timer-=tmin
                prelist.append(tcurr+tmin)
                
            elif t1<t0 and t1<t2: # AP occurrs
                bi = binomial(Mi, pri)
                v=v-ci*bi
                tmin = t1
                timer-=tmin
                prelisti.append(tcurr+tmin)

            else: # an inhibition event occurs
                # print('2')
                tmin=t2
                timer = delta_t
                if tcurr >= ratio*tmax:
                    vlist.append(v)
                    vthlist.append(vth)
                    tlist.append(tcurr)
                    
            tcurr += tmin

            if v>=vth:
                postlist.append(tcurr)
                v=0
                vth=vth0
                vlist[-1]=vth0+1e-3
                
            # Update the continuous dynamics
            
            v += (-v / tauv) * tmin
            vth += (vthmax(v, vth0, v1, alpha)-vth)/tauvth*tmin
    
        Tlist = np.diff(postlist)
        Tmean = np.mean(Tlist)
        CVT2=np.var(Tlist)/Tmean**2

        tavgs.append(Tmean)
        cavgs.append(CVT2)
    Tmean = np.mean(tavgs)
    CVT2 = np.mean(cavgs)
    return tlist, vlist, vthlist, prelist, prelisti, postlist, Tmean, CVT2

def vthmax(v, vthb, v1, alpha):
    if v < v1:
        return vthb
    if v>=v1:
        return vthb + alpha*(v-v1)

