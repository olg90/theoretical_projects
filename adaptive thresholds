        vthlist.append(vth)
        vlist.append(0)
        tlist.append(0)
        while tcurr < tmax:
            
            t0=exponential(1/(f+e))
            t1=exponential(1/(fi+e))
            t2=timer
            
            if t0<t1 and t0<t2: # AP occurrs
                b = binomial(M, pr)
                v=v+c*b
                tmin = t0
