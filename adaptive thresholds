    fout_fixed = 1 / resf[6]
    foutf.append(fout_fixed)
    noisef.append(resf[7])
    
    # ----- bisection search for matched mean -----
    target = fout_fixed
    
    v_low = vth0 * 0.1
    v_high = vth0 * 10
    
    r_low = estimate_rate(v_low, f)
    r_high = estimate_rate(v_high, f)
    
    # ensure bracket contains the solution
    if r_low < target:
        v_low, v_high = v_high, v_low
        r_low, r_high = r_high, r_low
    
