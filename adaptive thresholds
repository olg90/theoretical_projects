import matplotlib.pyplot as plt
from numpy.random import exponential, binomial, gamma
from numpy import exp
from numpy import sqrt as Sqrt
from numpy import log as Log
import pandas as pd

def simulate(vth, c, ci, f, fi, pr, pri, M, Mi, tauv, tmax, delta_t, navgs):

    tavgs=[]
    cavgs=[]

    for _ in range(navgs):

        vlist=[]
        vthlist=[]
        tlist=[]
        prelist=[]
        prelisti=[]
        postlist=[]
        
        e=1e-9
        tcurr=0
        ratio = 0.3
        timer = delta_t
        v=0
        tlist.append(0)
        vlist.append(0)
        vthlist.append(vth)
        while tcurr < tmax:
            
            t0=exponential(1/(f+e))
            t1=exponential(1/(fi+e))
            t2=timer
            
            if t0<t1 and t0<t2: # AP occurrs
                b = binomial(M, pr)
                v=v+c*b
                tmin = t0
                timer-=tmin
                prelist.append(tcurr+tmin)
                
            elif t1<t0 and t1<t2: # AP occurrs
                bi = binomial(Mi, pri)
                v=v-ci*bi
                tmin = t1
                timer-=tmin
                prelisti.append(tcurr+tmin)
    
            else:
                # print('2')
                tmin=t2
                timer = delta_t
                if tcurr >= ratio*tmax:
                    vlist.append(v)
                    vthlist.append(vth)
                    tlist.append(tcurr)
                    
            tcurr += tmin
            if v>=vth:
                if tcurr>ratio*tmax:
                    postlist.append(tcurr)
                v=0
                vlist[-1]=vth+0.001

            if tauv!=np.inf and tauv!=0:
                v += (-v / tauv) * tmin
            if tauv==0:
                v=0
    
        Tlist = np.diff(postlist)
        Tmean = np.mean(Tlist)
        CVT2=np.var(Tlist)/Tmean**2

        tavgs.append(Tmean)
        cavgs.append(CVT2)
    Tmean = np.mean(tavgs)
    CVT2 = np.mean(cavgs)
    return tlist[1:], vlist[1:], vthlist[1:], prelist, prelisti, postlist, Tmean, CVT2

