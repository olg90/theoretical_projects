import numpy as np
import matplotlib.pyplot as plt
from numpy.random import exponential, binomial
from scipy.stats import gamma as gamma_dist, lognorm, expon

# ---------------------------------------------------------------------
# Adaptive threshold function
# ---------------------------------------------------------------------
def vthmax(v, vth0, vthmin, vmin):
    if v >= 0:
        return vth0
    elif v <= vmin:
        return vthmin
    else:
        return vthmin + (vth0 - vthmin) * (v - vmin) / (0 - vmin)

# ---------------------------------------------------------------------
# Simulation function with negative adaptive threshold
# ---------------------------------------------------------------------
def sima(vth0, c, ci, f, fi, pr, pri, M, Mi, tauv, tmax, delta_t,
         tauvth, vmin, vthmin, navgs):

    tavgs=[]
    cavgs=[]

    all_postlist = []

    for _ in range(navgs):
        v = 0
        vth = vth0
        tcurr = 0
        timer = delta_t
        postlist = []

        while tcurr < tmax:
            # Generate inter-event times
            t0 = exponential(1/f)
            t1 = exponential(1/fi)
            t2 = timer

            if t0 < t1 and t0 < t2:
                b = binomial(M, pr)
                v += c*b
                tmin = t0
                timer -= tmin
            elif t1 < t0 and t1 < t2:
                bi = binomial(Mi, pri)
                v -= ci*bi
                tmin = t1
                timer -= tmin
            else:
                tmin = t2
                timer = delta_t

            tcurr += tmin

            # Spike generation
            if v >= vth:
                postlist.append(tcurr)
                v = 0
                vth = vth0

            # Continuous dynamics
            if tauv != 0:
                v += (-v/tauv) * tmin
            else:
                v = 0
            vth += (vthmax(v, vth0, vthmin, vmin) - vth)/tauvth * tmin

        # ISI statistics
        Tlist = np.diff(postlist)
        Tmean = np.mean(Tlist)
        CVT2 = np.var(Tlist)/Tmean**2

        tavgs.append(Tmean)
        cavgs.append(CVT2)
        all_postlist.extend(postlist)

    Tmean = np.mean(tavgs)
    CVT2 = np.mean(cavgs)

    return np.array(all_postlist), Tmean, CVT2

